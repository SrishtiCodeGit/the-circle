rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Leads — anyone can write (lead capture), only authenticated users can read
    match /leads/{id} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Gigs — anyone can read, authenticated users can create, owner can update/delete
    match /gigs/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // Collabs — anyone can read, authenticated users can create, owner can update/delete
    match /collabs/{id} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.uid;
    }

    // User profiles — users can read all, write only their own
    match /users/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
